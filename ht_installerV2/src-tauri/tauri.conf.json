{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WDG Snap Hutao Installer",
  "version": "0.1.0",
  "identifier": "com.wdg12.htInstallerV2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WDG Snap Hutao \u5b89\u88c5\u5668",
        "width": 920,
        "height": 660,
        "minWidth": 860,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
